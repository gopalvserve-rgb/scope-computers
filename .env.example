# Copy this file to .env.local for local dev, and set values in Vercel dashboard for production.

# Vercel Postgres (these variables are auto-injected when you create a Vercel Postgres DB and link it to the project)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# iron-session password (must be at least 32 characters). Generate: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Initial admin user (used by scripts/init-db to seed the first admin)
INITIAL_ADMIN_EMAIL=admin@myscopecomputers.com
INITIAL_ADMIN_PASSWORD=ChangeThisSecurePassword123!
INITIAL_ADMIN_NAME=Administrator
